APP_ENV=dev
DATABASE_PATH=gastos.db
HOST=0.0.0.0
PORT=3002
RELOAD=true
LOG_LEVEL=info
SQL_ECHO=false
CORS_ORIGINS=*
USER_REPO_BACKEND=jpa
MONEY_SOURCE_REPO_BACKEND=jpa
DEFAULT_TIMEZONE=America/Bogota

# Auth (JWT)
# En prod generar con: openssl rand -hex 32  (≥32 caracteres)
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440
BCRYPT_ROUNDS=12

# AI capture (Claude para parsear gastos en lenguaje natural)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_MAX_TOKENS=1024

# Adjuntos (recibos)
UPLOADS_DIR=uploads
MAX_ATTACHMENT_MB=10
ALLOWED_ATTACHMENT_MIMES=image/jpeg,image/png,image/webp,image/heic,application/pdf
